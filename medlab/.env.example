# ── Обязательно ───────────────────────────────────────────────────────────────
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Сервер ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── SMTP для сброса пароля ────────────────────────────────────────────────────
# Без настройки SMTP_HOST приложение работает в dev-режиме:
# токен сброса возвращается прямо в ответе API (удобно для разработки).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=MedLab <your@email.com>

# ── Публичный URL ─────────────────────────────────────────────────────────────
# Используется в ссылке письма сброса пароля.
# В dev-режиме можно не указывать.
APP_URL=https://your-domain.com
